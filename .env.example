# VoxSentinel Environment Variables Template
# Copy to .env and fill in values

# ── Database ──
TG_DB_URI=postgresql+asyncpg://voxsentinel:changeme@postgres:5432/voxsentinel
TG_DB_POOL_SIZE=10

# ── Redis ──
TG_REDIS_URL=redis://redis:6379/0

# ── ASR Backends ──
TG_DEEPGRAM_API_KEY=
TG_WHISPER_HOST=whisper:9090
TG_ASR_DEFAULT_BACKEND=deepgram_nova2
TG_ASR_FALLBACK_BACKEND=whisper_v3_turbo

# ── Slack Alerts ──
TG_SLACK_WEBHOOK_URL=
TG_SLACK_BOT_TOKEN=

# ── VAD ──
TG_VAD_THRESHOLD=0.5

# ── API ──
TG_API_KEY=changeme
TG_API_HOST=0.0.0.0
TG_API_PORT=8000

# ── Celery ──
TG_CELERY_BROKER_URL=redis://redis:6379/1
TG_CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Logging ──
TG_LOG_LEVEL=INFO

# ── YouTube Cookies (Netscape format — export via "Get cookies.txt LOCALLY" extension) ──
TG_COOKIES_FILE=cookies/vidcookie.txt

# ── Hugging Face (for pyannote.audio) ──
TG_HF_TOKEN=

# ── Data Retention ──
TG_RETENTION_DAYS=90

# ── AI Keyword Suggestions ──
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# ── YouTube Media Worker ──
# Set to delegate yt-dlp/FFmpeg operations to an external machine
# (home PC, VPS, etc.) where YouTube is not blocked.
# See yt_worker/README.md for setup instructions.
YT_WORKER_URL=
YT_WORKER_SECRET=
